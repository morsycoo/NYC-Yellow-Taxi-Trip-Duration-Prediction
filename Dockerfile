# ============================================================
# Base Image
# ============================================================

FROM python:3.13-slim

# ============================================================
# Working Directory
# ============================================================

WORKDIR /app

# ============================================================
# Copy Requirements
# ============================================================

COPY requirements.txt .

# ============================================================
# Install Dependencies
# ============================================================

RUN pip install --no-cache-dir -r requirements.txt

# ============================================================
# Copy Project
# ============================================================

COPY . .

# ============================================================
# Expose Port
# ============================================================

EXPOSE 8000

# ============================================================
# Start FastAPI
# ============================================================

CMD ["python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]